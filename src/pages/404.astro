---
// src/pages/404.astro
import Base from '../layouts/Base.astro';
---
<Base
  title="404 — page not indexed"
  description="The path you followed doesn't exist in this build."
  offline={true}
  footerRight="last known good state: /index"
>
  <div class="glitch" aria-hidden="true">
    <span class="r">404</span>
    <span class="t">404</span>
    <span class="m">404</span>
  </div>
  <p class="glitch-jp">不明</p>
  <h1 class="err-title">page not indexed</h1>
  <p class="err-dek">
    the path you followed doesn't exist in this build. either it never did, or it's been quietly
    removed. the rest of the site is still online — start from one of these:
  </p>

  <nav class="recovery">
    <a href="/"><b>← /index</b><i>start over</i></a>
    <a href="/primers"><b>/primers</b><i>fundamentals, explained</i></a>
    <a href="/log"><b>/log</b><i>research &amp; writeups</i></a>
    <a href="/#contact"><b>/contact</b><i>get in touch</i></a>
  </nav>

  <p class="epigraph">
    all those moments will be lost in time, like tears in rain.
    <span class="attr">— R. BATTY, 2019</span>
  </p>
</Base>

---
// src/layouts/Base.astro
// The page shell every other page extends.
import '../styles/global.css';
import Hud from '../components/Hud.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  context?: string;       // HUD right-side context
  offline?: boolean;      // 404 mode
  footerRight?: string;
}

const {
  title,
  description = 'asfandyar nawaz khan / eclipse708 — security researcher in training',
  context,
  offline = false,
  footerRight,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Theme + colour scheme -->
    <meta name="theme-color" content="#0d0b0a" />
    <meta name="color-scheme" content="dark" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800;900&family=Noto+Sans+JP:wght@300;400;500&family=VT323&display=swap"
      rel="stylesheet"
    />

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title="eclipse708" href="/rss.xml" />
  </head>
  <body>
    <Hud context={context} offline={offline} />
    <slot name="below-hud" />
    <main>
      <slot />
    </main>
    <Footer rightText={footerRight} />
  </body>
</html>
